# ============================================================
# ImageHub Environment Variables
# ============================================================

# ---- App ----
APP_PORT=3001
NODE_ENV=development

# ---- Web (Next.js) ----
WEB_URL=http://localhost:3000
API_URL=http://localhost:3001

# ---- MySQL ----
# Runtime database user. After initialization it only needs SELECT, INSERT, UPDATE, DELETE.
DATABASE_URL=mysql://imagehub:imagehub_secret@localhost:3306/imagehub

# Optional migration user for db:push / migrate. Use only during deploy/init.
# MIGRATION_DATABASE_URL=mysql://imagehub_migrator:imagehub_migration_secret@localhost:3306/imagehub

# Keep false in production runtime. Set true only for trusted first-run/dev environments.
AUTO_INIT_DB=false

MYSQL_ROOT_PASSWORD=root_secret
MYSQL_PASSWORD=imagehub_secret

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=imagehub_redis_secret

# ---- Meilisearch ----
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=imagehub_meili_secret
MEILISEARCH_INDEX_PREFIX=imagehub_

# ---- Storage ----
STORAGE_ROOT=./storage

# ---- Download ----
DOWNLOAD_TEMP_EXPIRE_MINUTES=5
DOWNLOAD_BATCH_MAX_EXPIRE_MINUTES=30

# ---- Upload ----
UPLOAD_MAX_FILE_SIZE_MB=200
